generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CUSTOMER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum MediaType {
  IMAGE
  VIDEO
}

enum CartStatus {
  ACTIVE
  CONVERTED
  ABANDONED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum FulfillmentStatus {
  UNFULFILLED
  PROCESSING
  SHIPPED
  DELIVERED
  RETURNED
}

enum CouponType {
  PERCENT
  FIXED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ContentType {
  GUIDE
  PAGE
  CAMPAIGN
  FAQ
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  REFUND
  LOGIN
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  name              String?
  phone             String?
  passwordHash      String?
  authProvider      String?
  role              UserRole           @default(CUSTOMER)
  status            UserStatus         @default(ACTIVE)
  addresses         Address[]
  carts             Cart[]
  orders            Order[]
  reviews           Review[]
  couponRedemptions CouponRedemption[]
  auditLogs         AuditLog[]          @relation("AuditActor")
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([status, createdAt])
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  phone     String
  province  String
  district  String
  ward      String
  line1     String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isDefault])
}

model Brand {
  id        String        @id @default(cuid())
  name      String
  slug      String        @unique
  status    ProductStatus @default(ACTIVE)
  metadata  Json?
  products  Product[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Category {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String?
  status      ProductStatus @default(ACTIVE)
  metadata    Json?
  products    Product[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Product {
  id             String           @id @default(cuid())
  name           String
  slug           String           @unique
  description    String
  shortDescription String
  status         ProductStatus    @default(DRAFT)
  brandId        String
  brand          Brand            @relation(fields: [brandId], references: [id], onDelete: Restrict)
  categoryId     String
  category       Category         @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  verdict        String?
  highlights     Json?
  considerations Json?
  seoTitle       String?
  seoDescription String?
  publishAt      DateTime?
  variants       ProductVariant[]
  media          ProductMedia[]
  reviews        Review[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([status, publishAt])
  @@index([categoryId, status])
  @@index([brandId, status])
}

model ProductVariant {
  id             String         @id @default(cuid())
  productId      String
  product        Product        @relation(fields: [productId], references: [id], onDelete: Restrict)
  sku            String         @unique
  name           String
  attributes     Json
  price          Int
  compareAtPrice Int?
  cost           Int?
  stock          Int            @default(0)
  lowStockAt     Int            @default(5)
  weightGrams    Int?
  status         ProductStatus  @default(ACTIVE)
  media          ProductMedia[]
  cartItems      CartItem[]
  orderItems     OrderItem[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([productId, status])
  @@index([stock, status])
}

model ProductMedia {
  id         String          @id @default(cuid())
  productId  String
  product    Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId  String?
  variant    ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  type       MediaType       @default(IMAGE)
  url        String
  alt        String
  sortOrder  Int             @default(0)
  createdAt  DateTime        @default(now())

  @@index([productId, sortOrder])
  @@index([variantId])
}

model Cart {
  id           String       @id @default(cuid())
  userId       String?
  user         User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionToken String?      @unique
  status       CartStatus   @default(ACTIVE)
  items        CartItem[]
  expiresAt    DateTime
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([userId, status])
  @@index([status, expiresAt])
}

model CartItem {
  id            String         @id @default(cuid())
  cartId        String
  cart          Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variantId     String
  variant       ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  quantity      Int
  priceSnapshot Int
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([cartId, variantId])
  @@index([variantId])
}

model Order {
  id                 String             @id @default(cuid())
  code               String             @unique
  userId             String?
  user               User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  guestEmail         String?
  guestPhone         String
  trackingTokenHash  String             @unique
  idempotencyKey     String             @unique
  status             OrderStatus        @default(PENDING)
  fulfillmentStatus  FulfillmentStatus  @default(UNFULFILLED)
  subtotal           Int
  discountTotal      Int                @default(0)
  shippingTotal      Int                @default(0)
  grandTotal         Int
  addressSnapshot    Json
  couponId           String?
  coupon             Coupon?            @relation(fields: [couponId], references: [id], onDelete: SetNull)
  items              OrderItem[]
  payments           Payment[]
  couponRedemptions  CouponRedemption[]
  internalNote       String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([status, createdAt])
  @@index([guestEmail, createdAt])
  @@index([guestPhone, createdAt])
  @@index([userId, createdAt])
}

model OrderItem {
  id              String          @id @default(cuid())
  orderId         String
  order           Order           @relation(fields: [orderId], references: [id], onDelete: Restrict)
  variantId       String?
  variant         ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  productSnapshot Json
  variantSnapshot Json
  skuSnapshot     String
  unitPrice       Int
  discountTotal   Int             @default(0)
  quantity        Int
  lineTotal       Int
  review          Review?
  createdAt       DateTime        @default(now())

  @@index([orderId])
  @@index([variantId])
}

model Payment {
  id             String        @id @default(cuid())
  orderId        String
  order          Order         @relation(fields: [orderId], references: [id], onDelete: Restrict)
  provider       String
  transactionId  String?
  amount         Int
  status         PaymentStatus @default(PENDING)
  rawReference   Json?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([provider, transactionId])
  @@index([orderId, status])
}

model Coupon {
  id              String             @id @default(cuid())
  code            String             @unique
  type            CouponType
  value           Int
  minimumSubtotal Int                @default(0)
  maximumDiscount Int?
  usageLimit      Int?
  usagePerUser    Int                @default(1)
  scope           Json?
  startsAt        DateTime
  endsAt          DateTime
  active          Boolean            @default(true)
  orders          Order[]
  redemptions     CouponRedemption[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([active, startsAt, endsAt])
}

model CouponRedemption {
  id         String   @id @default(cuid())
  couponId   String
  coupon     Coupon   @relation(fields: [couponId], references: [id], onDelete: Restrict)
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Restrict)
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  amount     Int
  createdAt  DateTime @default(now())

  @@unique([couponId, orderId])
  @@index([couponId, userId, createdAt])
}

model Review {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  productId   String
  product     Product      @relation(fields: [productId], references: [id], onDelete: Restrict)
  orderItemId String?      @unique
  orderItem   OrderItem?   @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  rating      Int
  title       String?
  content     String
  media       Json?
  status      ReviewStatus @default(PENDING)
  verified    Boolean      @default(false)
  sellerReply String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([productId, status, createdAt])
  @@index([userId, createdAt])
}

model ContentPage {
  id             String        @id @default(cuid())
  type           ContentType
  slug           String        @unique
  title          String
  excerpt        String?
  blocks         Json
  seoTitle       String?
  seoDescription String?
  status         ContentStatus @default(DRAFT)
  publishAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([type, status, publishAt])
}

model AuditLog {
  id         String      @id @default(cuid())
  actorId    String?
  actor      User?       @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action     AuditAction
  entityType String
  entityId   String
  metadata   Json?
  requestId  String?
  createdAt  DateTime    @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([actorId, createdAt])
}
